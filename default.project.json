{
  "name": "libre-duel",
  "emitLegacyScripts": false,
  "tree": {
    "$className": "DataModel",
    "Lighting": {
    "$properties": {
      "Ambient": [1, 1, 1],
      "ColorShift_Top": [1, 1, 1],
      "ColorShift_Bottom": [1, 1, 1],
      "Brightness": 2,
      "Outlines": false,
      "Technology": "Voxel"
    }
  },

    "ReplicatedStorage": {
      "$path": "./src/ReplicatedStorage"
    },
    "StarterPlayer": {
      "$path": "./src/StarterPlayer",
      "$properties": {
        "CharacterJumpHeight": 3.5,
        "CharacterUseJumpPower": false
      }
    },

    "ServerScriptService": {
      "$path": "./src/ServerScriptService"
    },

    "ServerStorage": {
      "$path": "./src/ServerStorage"
    },

    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true,
        "Gravity": 100
      },
      "$path": "./src/Workspace"
    }
  }
}